# Local-PDF dev env — copy to .env.local-pdf-test (gitignored) and fill in.
#
# Used by scripts/dev-local-pdf.sh. Each line is a shell assignment;
# `set -a` in the launcher auto-exports them.

# Whatever string you'll paste in the frontend login form. Any non-empty value.
GOLDENS_API_TOKEN=demo12345

# Where uploaded PDFs + sidecar JSONs live. Will be created if missing.
LOCAL_PDF_DATA_ROOT=/home/ktazefid/Documents/local-pdf-test/data

# Absolute path to the DocLayout-YOLO weights .pt file.
# Download once with:
#   source .venv/bin/activate
#   huggingface-cli download juliozhao/DocLayout-YOLO-DocStructBench \
#     doclayout_yolo_docstructbench_imgsz1024.pt \
#     --local-dir ~/models/doclayout-yolo
LOCAL_PDF_YOLO_WEIGHTS=/home/ktazefid/models/doclayout-yolo/doclayout_yolo_docstructbench_imgsz1024.pt

LLM_BACKEND=vllm_remote
VLLM_BASE_URL=http://127.0.0.1:8000/v1
VLLM_MODEL=Qwen/Qwen2.5-3B-Instruct
